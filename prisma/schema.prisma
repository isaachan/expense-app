generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Expense {
  id        String   @id @default(cuid())
  date      DateTime
  amount    Float
  category  String
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}